# ──────────────────────────────────────────────
# Shoppyfy — environment variables
# Copy to server/.env and client/.env (see sections)
# ──────────────────────────────────────────────

# ───── server/.env ─────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# PostgreSQL (matches docker-compose.yml — host port 5433)
# For Supabase: DATABASE_URL = pooled connection (port 6543, add ?pgbouncer=true),
#               DIRECT_URL   = direct connection (port 5432). See README.
DATABASE_URL=postgresql://shoppyfy:shoppyfy@localhost:5433/shoppyfy?schema=public
DIRECT_URL=postgresql://shoppyfy:shoppyfy@localhost:5433/shoppyfy?schema=public

# Redis (matches docker-compose.yml)
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cloudinary (https://console.cloudinary.com)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ───── client/.env ─────
VITE_API_URL=http://localhost:5000/api
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
